rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /medicines/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // read:true — login email/phone lookup before auth
    // sessionToken field updated on login for single-device enforcement
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // read:true — admin login lookup before auth
    // sessionToken field updated on login for single-device enforcement
    match /admins/{adminId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // read:true — rider login + delivery-dashboard getMe() query
    // sessionToken field updated on login for single-device enforcement
    match /riders/{riderId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /customCategories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /carts/{id} {
      allow read, write: if request.auth != null;
    }

    match /userAddresses/{id} {
      allow read, write: if request.auth != null;
    }

    // FIX 4: riderRequests — riders read their own, admins read all
    // rider dashboard authenticated hone ke baad hi read kare
    match /riderRequests/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /pharmacyProfiles/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Wishlists — user can only read/write their own
    match /wishlists/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Prescriptions — user can only read/write their own
    match /prescriptions/{docId} {
      allow read, write: if request.auth != null;
    }

    // Rider withdrawal requests
    match /riderWithdrawals/{docId} {
      allow read, write: if request.auth != null;
    }

    // Admin earnings / payout records
    match /adminPayouts/{docId} {
      allow read, write: if request.auth != null;
    }

    // Support tickets — customers/riders create, admins manage
    // FIX 4: Rate-limited writes — only authenticated or guests with valid structure
    // read:true so customers can read their own ticket status
    match /supportTickets/{ticketId} {
      allow read: if true;
      // Allow unauthenticated users to CREATE (guest support) but validate fields
      allow create: if request.resource.data.keys().hasAll(['ticketId','status','createdAt'])
                    && request.resource.data.status == 'open'
                    && request.resource.data.resolved == false;
      // Only authenticated users (admin/agent) can update/delete tickets
      allow update, delete: if request.auth != null;
    }
    match /supportTickets/{ticketId}/messages/{msgId} {
      allow read: if true;
      // Anyone can add a message (guest users too) but must have required fields
      allow create: if request.resource.data.keys().hasAll(['text','senderType','timestamp'])
                    && request.resource.data.text.size() < 2000;
      allow update, delete: if request.auth != null;
    }

  }
}
